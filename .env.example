# Copy this file to .env and fill in real values locally.
# Never commit a real .env file (it is listed in .gitignore).

# Server-side fallback Gemini API key.
# Used only when the user has not supplied their own key AND no local
# Ollama instance is reachable. Never exposed to the browser/client.
FALLBACK_GEMINI_API_KEY=

# Base URL for a local Ollama instance.
OLLAMA_HOST=http://localhost:11434

# Model name to use with Ollama.
OLLAMA_MODEL=llama3

# Gemini model name (used for both BYOK and fallback Gemini clients).
GEMINI_MODEL=gemini-2.5-flash
